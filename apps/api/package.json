{
  "name": "@flowboard/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:migrate": "node --import tsx src/scripts/migrate.ts",
    "db:seed": "node --import tsx src/scripts/seed.ts",
    "db:setup": "node --import tsx src/scripts/setup.ts"
  },
  "dependencies": {
    "@flowboard/shared": "*",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "supertest": "^7.1.4",
    "@types/supertest": "^6.0.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
